---
const {jobTitle, place, site, siteUrl, time} = Astro.props;
---
<style>
	h4 {
		font-size: 1.1rem;
		margin: 0;
	}

	span {
		font-weight: bold;
	}

@media print {
	a {
		color: black;
		text-decoration: none;
	}
}
</style>

<div>
	<div class=".employmentHeader">
		<h4>{jobTitle}</h4>
		<div>
		<span>{place}</span> 
		{siteUrl != null &&
			<> - <a href={siteUrl} target="_blank" rel="noopener noreferrer">{site}</a> </>
		}
		</div>
		{time}
	</div>
	<slot/>
</div>