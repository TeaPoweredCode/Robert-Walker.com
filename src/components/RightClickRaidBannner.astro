---
import { Image } from 'astro:assets';
import bannerImage from '../images/project_images/right-click-raid/RightClickRaid-bannerMini.png';
// style needs to be inline to stop leaking the global css and breaking font
---

<div style="height:280px; width:100%; margin:20px 0; background-color:#a970ff; overflow:hidden; position:relative;">
    <div style="font-size:64px; line-height:normal; color:#b17eff; transform:translate(-140px,-20px); white-space:nowrap; user-select:none;">            
        <div>right-click-raid right-click-raid right-click-raid right-click-raid right-click-raid</div>
        <div>click-raid right-click-raid right-click-raid right-click-raid right-click-raid right-</div>
        <div>raid right-click-raid right-click-raid right-click-raid right-click-raid right-click-</div>
        <div>right-click-raid right-click-raid right-click-raid right-click-raid right-click-raid</div>
    </div>
    <Image 
        src={bannerImage} 
        alt="Right click raid banner" 
        loading="eager"
        style="position:absolute; top:50%; left:50%; transform:translate(-50%, -50%); z-index:1;"
    />
</div>