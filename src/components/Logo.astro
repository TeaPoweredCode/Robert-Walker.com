---
	const { radius, stroke } = Astro.props;
	const height = radius * 2;
	const width = height * Math.sqrt(3) / 2;

	let points = [
		[width / 2, 0],
		[width, height / 4],
		[width, height * 3 / 4],
		[width / 2, height],
		[0, height * 3 / 4],
		[0, height / 4]
	];

	let twoDp = (num : number) =>{return Math.trunc(num * 100) /100}; 
	points.map(xy => { xy[0] = twoDp(xy[0] + stroke); xy[1] = twoDp(xy[1] + stroke); });

	let shapeData = {
		width : Math.ceil(width) + (stroke*2),
		height : Math.ceil(height) + (stroke*2),		
		path : points.map(p => `${p[0]},${p[1]}`).join(' ')
	};

